# Copia este archivo como ".env" en la misma carpeta y rellena valores reales.
# NUNCA subas el archivo ".env" real al repo (agregalo a .gitignore).

# Contraseña root de MariaDB
MYSQL_ROOT_PASSWORD=cambia_esta_clave

# Usuario y contraseña del administrador inicial de OpenEMR
OE_USER=admin
OE_PASS=cambia_esta_clave_tambien

# Puerto en el host donde quedará expuesto OpenEMR (https)
OPENEMR_HOST_PORT=8443
