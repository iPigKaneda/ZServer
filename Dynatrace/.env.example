# Copia este archivo como ".env" en esta misma carpeta y rellena los valores.
# docker compose lo carga automáticamente si está en el mismo directorio que el .yml.

# Contraseña del usuario de MongoDB (ET_DATABASE_USER=etAdmin) usado por backend/frontend
ET_DATABASE_PASSWORD=

# API Key de Datadog (Organization Settings > API Keys) usada por el datadog-agent
DD_API_KEY=
